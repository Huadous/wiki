# ── Obsidian Core ──
# workspace states (different per device)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# hotkeys may differ per device
.obsidian/hotkeys.json

# trash
.trash/

# OS junk
**/.DS_Store
**/Thumbs.db

# ── AI / LLM Plugin Data: embeddings & indexes (large, device-local) ──

# Smart Connections
.smart-connections/
.smart-env/

# Copilot
.copilot-index/
.obsidian/copilot-index/

# Local LLM model files (.gguf etc are GB-sized)
**/*.gguf
**/*.bin
**/*.pt
**/*.onnx
**/*.safetensors
/models/

# Generic AI plugin caches
**/.ai_cache/
**/.embeddings/
**/.vectorstore/
**/.chroma/

# ── API Keys & Secrets ──
.obsidian/plugins/karpathywiki/data.json
.env
.env.local
.env.*.local
**/api_keys.json

# ── Git plugin local state (changes every commit) ──
.obsidian/plugins/obsidian-git/data.json

# ── General ──
node_modules/
*.log
*.tmp

# ── Quartz 4 build output ──
public/
